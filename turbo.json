{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build", "lint", "typecheck"],
      "outputs": ["dist/**"]
    },
    "test": {},
    "test:e2e": {
      "cache": false
    },
    "typecheck": {},
    "lint": {}
  }
}
